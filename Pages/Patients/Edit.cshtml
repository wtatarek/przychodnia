@page "{id:guid}"
@model ClinicManager.Pages.Patients.EditModel
@{
    ViewData["Title"] = "Edytuj pacjenta";
}

<h2>Edytuj pacjenta</h2>

<form method="post" class="row g-3 mt-2" style="max-width:600px">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="col-12">
        <label asp-for="Input.Pesel" class="form-label">PESEL (11 cyfr)</label>
        <input asp-for="Input.Pesel" class="form-control" />
        <span asp-validation-for="Input.Pesel" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.FirstName" class="form-label">Imię</label>
        <input asp-for="Input.FirstName" class="form-control" />
        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Input.LastName" class="form-label">Nazwisko</label>
        <input asp-for="Input.LastName" class="form-control" />
        <span asp-validation-for="Input.LastName" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Input.InsuranceNumber" class="form-label">Numer ubezpieczenia (opcjonalnie)</label>
        <input asp-for="Input.InsuranceNumber" class="form-control" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Zapisz zmiany</button>
        <a asp-page="Index" class="btn btn-secondary">Anuluj</a>
    </div>
</form>
