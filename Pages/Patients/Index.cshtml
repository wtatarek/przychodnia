@page
@model ClinicManager.Pages.Patients.IndexModel
@{
    ViewData["Title"] = "Pacjenci";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Pacjenci</h2>
    <a asp-page="Create" class="btn btn-primary">+ Dodaj pacjenta</a>
</div>

<!-- Wyszukiwarka -->
<form method="get" class="row g-3 mb-4">
    <div class="col-md-4">
        <input type="text" name="pesel" class="form-control" placeholder="PESEL" value="@Model.Pesel">
    </div>
    <div class="col-md-4">
        <input type="text" name="lastName" class="form-control" placeholder="Nazwisko" value="@Model.LastName">
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Szukaj</button>
    </div>
    <div class="col-md-2">
        <a asp-page="Index" class="btn btn-outline-secondary w-100">Wyczyść</a>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Patients.Count == 0)
{
    <div class="alert alert-info">Brak pacjentów.</div>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>PESEL</th>
                <th>Imię</th>
                <th>Nazwisko</th>
                <th>Ubezpieczenie</th>
                <th style="width:200px">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Patients)
            {
                <tr>
                    <td>@p.Pesel</td>
                    <td>@p.FirstName</td>
                    <td>@p.LastName</td>
                    <td>@(p.InsuranceNumber ?? "-")</td>
                    <td>
                        <a asp-page="/MedicalRecords/Index" asp-route-patientId="@p.Id" class="btn btn-sm btn-outline-info">Kartoteka</a>
                        <a asp-page="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">Edytuj</a>
                        <a asp-page="Delete" asp-route-id="@p.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
