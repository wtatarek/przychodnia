@page "{id:guid}"
@model ClinicManager.Pages.Visits.EditModel
@{
    ViewData["Title"] = "Edytuj wizytę";
}

<h2>Edytuj wizytę</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" class="row g-3 mt-2" style="max-width:600px">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="col-12">
        <label class="form-label">Pacjent</label>
        <input class="form-control" value="@Model.PatientName" readonly />
    </div>
    <div class="col-12">
        <label asp-for="Input.AssignedDoctorId" class="form-label">Lekarz</label>
        <select asp-for="Input.AssignedDoctorId" asp-items="Model.DoctorList" class="form-select"></select>
        <span asp-validation-for="Input.AssignedDoctorId" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Input.ScheduledAt" class="form-label">Data i godzina</label>
        <input asp-for="Input.ScheduledAt" type="datetime-local" class="form-control" />
        <span asp-validation-for="Input.ScheduledAt" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label class="form-label">Status</label>
        <input class="form-control" value="@Model.CurrentStatus" readonly />
    </div>
    <div class="col-12">
        <label asp-for="Input.Notes" class="form-label">Notatki</label>
        <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Zapisz</button>
        <a asp-page="Index" class="btn btn-secondary">Anuluj</a>
    </div>
</form>
