<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true">

    <!-- targets: gdzie logi mają być zapisywane -->
    <targets>
        <!-- Logi błędów do /logs/errors.log -->
        <target name="errorFile"
                xsi:type="File"
                fileName="${basedir}/logs/errors.log"
                layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message} ${exception:format=tostring}"
                archiveFileName="${basedir}/logs/errors.{#}.log"
                archiveEvery="Day"
                archiveNumbering="Rolling"
                maxArchiveFiles="7"
                keepFileOpen="false" />

        <!-- Wszystkie logi do /logs/all.log -->
        <target name="allFile"
                xsi:type="File"
                fileName="${basedir}/logs/all.log"
                layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message}"
                archiveFileName="${basedir}/logs/all.{#}.log"
                archiveEvery="Day"
                archiveNumbering="Rolling"
                maxArchiveFiles="3"
                keepFileOpen="false" />

        <!-- Konsola (development) -->
        <target name="console"
                xsi:type="Console"
                layout="${level:uppercase=true}: ${message}" />
    </targets>

    <rules>
        <!-- Wszystkie błędy → errors.log -->
        <logger name="*" minlevel="Error" writeTo="errorFile" />

        <!-- Wszystkie logi (Info+) → all.log -->
        <logger name="*" minlevel="Info" writeTo="allFile" />

        <!-- Konsola tylko w development -->
        <logger name="*" minlevel="Info" writeTo="console" />

        <!-- Wyciszenie szumu od Entity Framework i ASP.NET -->
        <logger name="Microsoft.*" maxlevel="Warning" final="true" />
        <logger name="System.Net.Http.*" maxlevel="Warning" final="true" />
    </rules>
</nlog>
